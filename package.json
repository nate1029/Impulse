{
  "name": "arduino-ide-cursor",
  "version": "1.0.0",
  "description": "AI-powered Arduino IDE alternative with intelligent error detection",
  "main": "src/main/main.js",
  "scripts": {
    "prestart": "vite build",
    "start": "electron .",
    "dev": "concurrently --kill-others \"vite\" \"wait-on http://localhost:5173 && electron . --dev\"",
    "dev:renderer": "vite",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && electron-builder",
    "build:win": "npm run build:renderer && electron-builder --win",
    "build:mac": "npm run build:renderer && electron-builder --mac",
    "build:linux": "npm run build:renderer && electron-builder --linux",
    "build:all": "npm run build:renderer && electron-builder --win --mac --linux",
    "postinstall": "electron-builder install-app-deps",
    "test": "jest",
    "lint": "eslint src/ --ext .js",
    "lint:fix": "eslint src/ --ext .js --fix",
    "audit": "npm audit --production"
  },
  "keywords": [
    "arduino",
    "iot",
    "ide",
    "electron"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^40.4.1",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-plugin-security": "^3.0.1",
    "jest": "^29.7.0",
    "vite": "^6.4.1",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "@google/generative-ai": "^0.24.1",
    "@rollup/rollup-win32-x64-msvc": "^4.57.1",
    "chokidar": "^3.5.3",
    "codemirror": "^5.65.18",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.7.3",
    "node-pty": "^1.1.0",
    "openai": "^4.20.0",
    "serialport": "^12.0.0",
    "y-webrtc": "^10.3.0",
    "yjs": "^13.6.29",
    "zod": "^3.23.8"
  },
  "build": {
    "appId": "com.impulseide.app",
    "productName": "Impulse IDE",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/main/**/*",
      "dist-renderer/**/*",
      "assets/**/*",
      "!**/*.map"
    ],
    "publish": {
      "provider": "github",
      "owner": "your-github-org",
      "repo": "arduino-ide-cursor"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "signingHashAlgorithms": [
        "sha256"
      ],
      "certificateSubjectName": "${env.WIN_CSC_SUBJECT_NAME}",
      "signAndEditExecutable": true
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "differentialPackage": true
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "identity": "${env.MAC_CSC_NAME}"
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "category": "Development",
      "maintainer": "Impulse IDE <hello@impulseide.dev>",
      "desktop": {
        "StartupWMClass": "impulse-ide"
      }
    },
    "appImage": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  }
}
